{
  "name": "express-typeorm-postgres-example",
  "version": "1.0.0",
  "description": "Minimal Express + PostgreSQL + TypeORM with migrations and integration tests",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "test": "node ./node_modules/jest/bin/jest.js --runInBand",
    "migration:generate": "node ./node_modules/typeorm/cli.js migration:generate --dataSource src/data-source.js",
    "migration:run": "node ./node_modules/typeorm/cli.js migration:run --dataSource src/data-source.js"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "express": "^4.18.4",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.1.13",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
